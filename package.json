{
  "name": "zohopay",
  "version": "1.0.0",
  "description": "TypeScript SDK for the Zoho Payments API — supports IN, IN Sandbox, and US editions",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "serve": "bunx serve .",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["zoho", "payments", "sdk", "api", "oauth"],
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "undici": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
